{
  "name": "@nexus-ai/cli",
  "version": "0.1.0",
  "description": "Nexus CLI - entry point, arg parsing, surface detection",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "nexus": "dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target=node --external @nexus-ai/*",
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nexus-ai/core": "workspace:*",
    "@nexus-ai/tui": "workspace:*",
    "@nexus-ai/headless": "workspace:*",
    "@nexus-ai/agent": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.5.5",
    "typescript": "^5.6.2"
  }
}