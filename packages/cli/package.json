{
  "name": "@nexus-ai/cli",
  "version": "0.1.0",
  "description": "Nexus CLI - entry point, arg parsing, surface detection",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "bin": {
    "nexus-cli": "src/index.ts"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target=node --external @nexus-ai/*",
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nexus-ai/core": "workspace:*",
    "@nexus-ai/tui": "workspace:*",
    "@nexus-ai/headless": "workspace:*",
    "@nexus-ai/agent": "workspace:*",
    "@nexus-ai/session": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.5.5",
    "typescript": "^5.6.2"
  }
}
