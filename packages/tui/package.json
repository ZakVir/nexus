{
  "name": "@nexus-ai/tui",
  "version": "0.1.0",
  "description": "Nexus Terminal UI - SolidJS + OpenTUI renderer",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --external @nexus-ai/* --splitting --target=node",
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nexus-ai/core": "workspace:*",
    "@nexus-ai/models": "workspace:*",
    "@nexus-ai/session": "workspace:*",
    "solid-js": "^1.9.1",
    "@opentui/core": "^0.1.0",
    "@opentui/solid": "^0.1.0",
    "chalk": "^5.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.5",
    "typescript": "^5.6.2"
  }
}