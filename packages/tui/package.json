{
  "name": "@nexus-ai/tui",
  "version": "0.1.0",
  "description": "Nexus Terminal UI - ANSI renderer for the interactive human surface",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --external @nexus-ai/* --splitting --target=node",
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nexus-ai/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.5.5",
    "typescript": "^5.6.2"
  }
}
