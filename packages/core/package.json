{
  "name": "@nexus-ai/core",
  "version": "0.1.0",
  "description": "Core Nexus functionality - providers, models, sessions, tools, config",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./config": {
      "import": "./dist/config.mjs",
      "require": "./dist/config.js",
      "types": "./dist/config.d.ts"
    },
    "./providers": {
      "import": "./dist/providers.mjs",
      "require": "./dist/providers.js",
      "types": "./dist/providers.d.ts"
    },
    "./models": {
      "import": "./dist/models.mjs",
      "require": "./dist/models.js",
      "types": "./dist/models.d.ts"
    },
    "./session": {
      "import": "./dist/session.mjs",
      "require": "./dist/session.js",
      "types": "./dist/session.d.ts"
    },
    "./tools": {
      "import": "./dist/tools.mjs",
      "require": "./dist/tools.js",
      "types": "./dist/tools.d.ts"
    }
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --external @nexus-ai/* --splitting",
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.2.2",
    "zod": "^3.23.8",
    "chalk": "^5.3.0",
    "yaml": "^2.5.1",
    "jose": "^5.9.2",
    "keyv": "^5.2.3",
    "keyv-sqlite": "^3.7.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^22.5.5"
  }
}