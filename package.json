{
  "name": "@nexus-ai/nexus-cli",
  "version": "0.1.0",
  "description": "Multi-model AI CLI tool for humans and agents",
  "private": false,
  "bin": {
    "nexus-cli": "bin/nexus-cli"
  },
  "files": [
    "bin/",
    "packages/*/dist/",
    "packages/*/src/",
    "themes/",
    "README.md"
  ],
  "scripts": {
    "build": "bun run --filter=@nexus-ai/core build && bun run --filter=@nexus-ai/headless build && bun run --filter=@nexus-ai/agent build && bun run --filter=@nexus-ai/tools build && bun run --filter=@nexus-ai/plugins build && bun run --filter=@nexus-ai/tui build && bun run --filter=@nexus-ai/cli build",
    "build:all": "bun run --filter=* build",
    "dev": "bun run --filter=@nexus-ai/cli dev",
    "test": "bun test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "prepare": "bun run build",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/bun": "latest",
    "typescript": "^5.6.2"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "packageManager": "bun@1.1.0",
  "keywords": [
    "ai",
    "cli",
    "multi-model",
    "tui",
    "terminal",
    "llm",
    "coding",
    "agent"
  ],
  "author": "Nexus Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nexus-ai/nexus"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "zod": "^4.4.3"
  }
}